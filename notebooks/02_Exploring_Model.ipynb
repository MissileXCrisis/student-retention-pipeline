   "source": [
    "Print the Exact Node Count"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "979b9aff",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total Trees: 100\n",
      "Total Nodes: 45,462\n"
     ]
    }
   ],
   "source": [
    "import joblib\n",
    "\n",
    "model = joblib.load(\"../models/retention_model.joblib\")\n",
    "total_nodes = sum(tree.tree_.node_count for tree in model.estimators_)\n",
    "\n",
    "print(f\"Total Trees: {len(model.estimators_)}\")\n",
    "print(f\"Total Nodes: {total_nodes:,}\")"
   ]
  },
